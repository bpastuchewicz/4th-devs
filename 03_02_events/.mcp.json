{
  "mcpServers": {
    "files": {
      "transport": "stdio",
      "command": "npx",
      "args": ["tsx", "../mcp/files-mcp/src/index.ts"],
      "env": {
        "LOG_LEVEL": "info",
        "FS_ROOT": "./workspace/project"
      }
    },
    "web": {
      "transport": "stdio",
      "command": "npx",
      "args": ["tsx", "../mcp/web/src/index.ts"],
      "env": {
        "LOG_LEVEL": "info",
        "WEB_SEARCH_PROVIDER": "duckduckgo",
        "OUTPUT_MODE": "file",
        "OUTPUT_DIR": "./workspace/project/notes/web"
      }
    }
  }
}
