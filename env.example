OPENAI_API_KEY=
OPENROUTER_API_KEY=
AI_PROVIDER=

# GitHub Copilot (default when GITHUB_TOKEN is set and no OpenAI/OpenRouter key)
# Generate a PAT with Copilot access at: https://github.com/settings/tokens
GITHUB_TOKEN=
COPILOT_MODEL=gpt-4.1

GEMINI_API_KEY=
REPLICATE_API_TOKEN=

RESEND_API_KEY=
RESEND_FROM=
SEED_API_KEY=

# Optional for 01_05_agent:
# DATABASE_URL=file:.data/agent.db
# DATABASE_AUTH_TOKEN=

# Optional for OpenRouter:
# OPENROUTER_HTTP_REFERER=https://your-site.example
# OPENROUTER_APP_NAME=AI_devs_examples