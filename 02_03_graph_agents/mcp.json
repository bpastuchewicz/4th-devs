{
  "mcpServers": {
    "files": {
      "command": "npx",
      "args": ["tsx", "../mcp/files-mcp/src/index.ts"],
      "env": {
        "LOG_LEVEL": "info",
        "FS_ROOT": "./workspace",
        "FS_ROOTS": "./workspace"
      }
    },
    "symfony-stdio": {
      "type": "stdio",
      "command": "php",
      "args": [
        "/home/bpast/php/copilot-mcp/bin/console",
        "mcp:server"
      ],
      "env": {
        "APP_ENV": "dev"
      }
    }
  }
}
